APP_NAME=PriorixCore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-core
DB_PORT=3306
DB_DATABASE=priorix_core
DB_USERNAME=priorix
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

JWT_SECRET=

CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIME=30
CB_TIMEOUT=5

GAMIFICATION_SERVICE_URL=http://gamification/api/gamification
STATISTICS_SERVICE_URL=http://gamification/api/statistics
INTERNAL_SERVICE_SECRET=change-me

JAEGER_ENDPOINT=http://jaeger:4318/v1/traces
PROMETHEUS_STORAGE_ADAPTER=redis
